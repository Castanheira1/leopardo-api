# Banco de dados (Supabase Postgres)
# Transaction pooler (IPv4): Supabase → Database → Connect → Transaction pooler
# DATABASE_URL=postgresql://postgres.vsxnqtecnvhhvekmkshb:SENHA@aws-1-us-east-2.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vagao

# Segurança (mínimo 32 caracteres)
JWT_SECRET=troque-por-um-segredo-bem-grande-aqui

# CORS: origens externas autorizadas a chamar a API (separadas por vírgula).
# Vazio = nenhuma origem externa (o PWA é servido pela mesma origem e continua
# funcionando). Ex.: CORS_ORIGINS=https://vagao.suaempresa.com
CORS_ORIGINS=

# Anti-força-bruta: máximo de tentativas em rotas de credencial
# (login/cadastro/recuperação) por IP a cada 15 min. Padrão: 20.
AUTH_RATE_MAX=20

# Servidor
PORT=3000
NODE_ENV=development

# Supabase Storage (fotos: selfies e fotos de carro)
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_KEY=sua-service-role-ou-anon-key
SUPABASE_BUCKET=veiculos

# Google Maps (mapa + Places Autocomplete no front)
GOOGLE_MAPS_API_KEY=sua-google-maps-api-key
# Map ID (Cloud Console → Map Management). DEMO_MAP_ID funciona em dev.
GOOGLE_MAPS_MAP_ID=DEMO_MAP_ID
# Routes API (linha pela pista) — DESLIGADA por padrão (custa dinheiro).
# Só ligue se aceitar a fatura Google. Com off: /api/rotas devolve linha reta.
# GOOGLE_ROUTES_ENABLED=1
# Tetos do APP (servidor). O painel CEO NÃO altera o console Google.
# Vale o menor: console GCP (duro) vs estes env (app cai em reta antes de chamar).
# Regra: ROTAS_GOOGLE_MAX_DIA ≤ cota ComputeRoutes no GCP.
# Aumentar: console primeiro, env depois. Diminuir: env primeiro, console depois.
# Cota GCP informada no painel CEO (API Maps) é só referência manual (tabela app_config).
# Franquia grátis Routes Essentials ≈ 10.000/mês — a prévia no painel é projeção do env.
# ROTAS_GOOGLE_MAX_DIA=300
# ROTAS_GOOGLE_MAX_MIN=30
# ROTAS_GOOGLE_MAX_MES=9000

# Raio (km) para considerar origem/destino "perto" no match
RAIO_MATCH_KM=3
RAIO_PROXIMO_KM=4

# Notificações push (Web Push / VAPID). Sem isto, o app sobe e só não envia push.
# Gere um par com:  node -e "console.log(require('web-push').generateVAPIDKeys())"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contato@vap.app

# Push nativo FCM HTTP v1 (firebase-admin). A API legada FCM_SERVER_KEY foi desligada
# pelo Google em 2024 — NÃO use server key. Cole o JSON da service account (uma linha
# ou com \n escapados) do Firebase Console → Project settings → Service accounts.
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...",...}
# FIREBASE_PROJECT_ID=seu-projeto-firebase
# Local: caminho para o arquivo .json
# GOOGLE_APPLICATION_CREDENTIALS=C:\segredo\firebase-adminsdk.json
# Também coloque android/app/google-services.json no app nativo (Capacitor).

# Assinatura Android local (opcional; CI usa GitHub Secrets equivalentes).
# ANDROID_KEYSTORE_PATH=C:\caminho\vap-release.jks
# ANDROID_KEYSTORE_PASSWORD=
# ANDROID_KEY_ALIAS=vap
# ANDROID_KEY_PASSWORD=

# Email — notificação de solicitação de acesso admin (Resend: https://resend.com)
RESEND_API_KEY=
EMAIL_FROM=VAP <noreply@seudominio.com>
ADMIN_EMAIL_NOTIFICACAO=seu.email@empresa.com

# Senha do admin semente (matricula 000000). Em producao, sem esta env e com a
# senha padrao admin123 ainda ativa, a conta admin e DESATIVADA no boot.
ADMIN_SENHA=

# Matriculas com poder de dono (visão multi-projeto, projetos, saúde). Separadas por vírgula.
# 000000 = admin semente de ops; 900000 = dono da empresa (criado no boot).
# Só o dono/CEO (dono.html). Admin canteiro 000000 NÃO entra aqui.
SUPER_ADMIN_MATRICULAS=900000

# Conta "Dono da empresa" (dashboard executivo). Criada no boot se não existir.
# DONO_MATRICULA=900000
# DONO_SENHA=troque-em-producao
