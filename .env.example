# Banco de dados (Supabase Postgres)
# Transaction pooler (IPv4): Supabase → Database → Connect → Transaction pooler
# DATABASE_URL=postgresql://postgres.vsxnqtecnvhhvekmkshb:SENHA@aws-1-us-east-2.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vagao

# Segurança (mínimo 32 caracteres)
JWT_SECRET=troque-por-um-segredo-bem-grande-aqui

# CORS: origens externas autorizadas a chamar a API (separadas por vírgula).
# Vazio = nenhuma origem externa (o PWA é servido pela mesma origem e continua
# funcionando). Ex.: CORS_ORIGINS=https://vagao.suaempresa.com
CORS_ORIGINS=

# Anti-força-bruta: máximo de tentativas em rotas de credencial
# (login/cadastro/recuperação) por IP a cada 15 min. Padrão: 20.
AUTH_RATE_MAX=20

# Servidor
PORT=3000
NODE_ENV=development

# Supabase Storage (fotos: selfies e fotos de carro)
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_KEY=sua-service-role-ou-anon-key
SUPABASE_BUCKET=veiculos

# Google Maps (mapa + Places Autocomplete no front)
GOOGLE_MAPS_API_KEY=sua-google-maps-api-key
# Map ID (Cloud Console → Map Management). DEMO_MAP_ID funciona em dev.
GOOGLE_MAPS_MAP_ID=DEMO_MAP_ID

# Raio (km) para considerar origem/destino "perto" no match
RAIO_MATCH_KM=3

# Notificações push (Web Push / VAPID). Sem isto, o app sobe e só não envia push.
# Gere um par com:  node -e "console.log(require('web-push').generateVAPIDKeys())"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contato@vap.app

# Email — notificação de solicitação de acesso admin (Resend: https://resend.com)
RESEND_API_KEY=
EMAIL_FROM=VAP <noreply@seudominio.com>
ADMIN_EMAIL_NOTIFICACAO=seu.email@empresa.com
